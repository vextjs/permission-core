{
    "name": "permission-core",
    "version": "2.0.0",
    "description": "Fine-grained RBAC and resource permission core for Node.js, with route permissions, data scopes, role inheritance, and wildcard matching.",
    "keywords": [
        "rbac",
        "permissions",
        "authorization",
        "access-control",
        "nodejs",
        "typescript",
        "route-permissions",
        "data-permissions",
        "role-inheritance",
        "wildcard-matching"
    ],
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./match": {
            "types": "./dist/match.d.ts",
            "import": "./dist/match.js",
            "require": "./dist/match.cjs"
        },
        "./plugins/vext": {
            "types": "./dist/plugins/vext.d.ts",
            "import": "./dist/plugins/vext.js",
            "require": "./dist/plugins/vext.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vextjs/permission-core.git"
    },
    "homepage": "https://vextjs.github.io/permission-core",
    "bugs": {
        "url": "https://github.com/vextjs/permission-core/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:contract": "vitest run test/contract",
        "test:unit": "vitest run test/unit",
        "test:integration": "vitest run test/integration",
        "test:complexity": "node ./scripts/check-complexity.mjs",
        "test:coverage": "vitest run --coverage && node ./scripts/check-coverage.mjs",
        "test:package": "node ./scripts/package-install-smoke.mjs",
        "test:docs": "node ./scripts/check-docs.mjs",
        "test:docs:rendered": "node ./scripts/check-docs-rendered.mjs",
        "docs:first-success": "npm run build && node ./scripts/docs-first-success-smoke.mjs",
        "docs:assemble": "node ./scripts/assemble-docs-site.mjs",
        "test:watch": "vitest",
        "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
        "example:basic": "npm run build && node ./examples/basic.mjs",
        "example:multi-tenant": "npm run build && node ./examples/multi-tenant.mjs",
        "example:data-guard": "npm run build && node ./examples/data-guard.mjs",
        "example:menu-admin": "npm run build && node ./examples/menu-admin.mjs",
        "example:vext": "npm run build && node ./examples/vext/index.mjs",
        "example:all": "npm run build && node ./examples/basic.mjs && node ./examples/multi-tenant.mjs && node ./examples/data-guard.mjs && node ./examples/menu-admin.mjs && node ./examples/vext/index.mjs",
        "test:audit": "npm audit --omit=dev --registry=https://registry.npmjs.org/",
        "test:all": "npm run typecheck && npm run test:complexity && npm run test:coverage && npm run test:docs && npm run build && npm run example:all && npm run test:package",
        "test:all:with-audit": "npm run test:all && npm run test:audit",
        "prepublishOnly": "npm run test:all:with-audit"
    },
    "peerDependencies": {
        "monsqlize": "3.1.0",
        "vextjs": "0.3.26"
    },
    "peerDependenciesMeta": {
        "vextjs": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "22.19.19",
        "@vitest/coverage-v8": "3.2.6",
        "mongodb-memory-server": "10.4.3",
        "monsqlize": "3.1.0",
        "parse5": "7.3.0",
        "tsup": "8.5.1",
        "typescript": "5.9.3",
        "vextjs": "0.3.26",
        "vitest": "3.2.6"
    }
}
