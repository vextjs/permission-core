{
    "name": "permission-core",
    "version": "0.2.0",
    "description": "Fine-grained permission core for Node.js with unified action + resource semantics.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./match": {
            "types": "./dist/match.d.ts",
            "import": "./dist/match.js",
            "require": "./dist/match.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit"
    },
    "dependencies": {
        "cache-hub": "^1.0.0",
        "monsqlize": "^1.3.0"
    },
    "devDependencies": {
        "@types/node": "^22.19.19",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
}