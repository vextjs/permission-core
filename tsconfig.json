{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": [
            "node"
        ],
        "rootDir": "."
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsup.config.ts",
        "vitest.config.ts"
    ]
}